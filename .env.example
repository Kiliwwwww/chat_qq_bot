DRIVER=~fastapi
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
SUPERUSERS=[""]
NICKNAME=[]
COMMAND_START=["/", ""]

# AI 配置
ai_api_key=xxx
ai_base_url=xxx
ai_model=mimo-v2.5
ai_max_tokens=1024
ai_temperature=1.0
ai_top_p=0.95


# 管理员QQ号（只有此人可修改群/用户白名单设置）
admin_qq=xxx

# 群消息回复概率 (0.0~1.0)
group_reply_chance=0.01

# 调试日志开关（开启后会打印发送给AI的完整JSON）
ai_debug_log=false

# 本地存储使用当前目录
LOCALSTORE_USE_CWD=true